            <name>RAF proto-oncogene serine/threonine-protein kinase</name>
            <uniprot-id>P04049</uniprot-id>
            <description>Involved in the transduction of mitogenic signals from the cell membrane to the nucleus. Part of the Ras-dependent signaling pathway from receptors to the nucleus. Protects cells from apoptosis mediated by STK3</description>
            <hmdbp-id>HMDBP01153</hmdbp-id>
            <gene-name>RAF1</gene-name>
            <locus>3p25</locus>
